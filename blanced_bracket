#include<bits/stdc++.h>
using namespace std;
int main(){
    string s;
    cout<<"Enter the string : ";
    cin>>s;
    int size = s.size();
    stack<char> st;
    for(int i=0;i<size;i++){
        if(s[i]=='(') st.push_back('(');
        else{
            if(st.size() == 0){ 
                cout<<"invalid string"<<endl;
                return 1;
            }
            st.pop();
        }
    }
    if(st.size != 0) cout<<"not a valid string"<<endl;
    else cout<<"valid string"<<endl;
    return 1;
}
