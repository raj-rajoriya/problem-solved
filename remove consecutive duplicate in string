#include<bits/stdc++.h>
using namespace std;
int main(){
    string s;
    cout<<"Enter the string : ";
    cin>>s;
    int size = s.size();
    stack<char> st;
    st.push(s[0]);
    for(int i=1;i<size;i++){
        if(st.top() != s[i]) st.push(s[i]);
    }
    string str = "";
    while(st.size() != 0){
        str = st.top() + str;
        st.pop();
    }
    cout<<str<<endl;
    return 1;
}
